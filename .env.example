# Supabase (опционально). Если НЕ заданы — дашборд читает данные из data/competition.ts.
# Project Settings → API в дашборде Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role ключ — ТОЛЬКО на сервере, нужен для записи из /admin. Никогда не коммитить.
SUPABASE_SERVICE_ROLE_KEY=

# Пароль для входа в /admin. Если не задан — админка показывает "не настроена".
ADMIN_PASSWORD=

# ── Live prices (TwelveData) ──────────────────────────────────────────────────
# API-ключ для подтягивания текущих рыночных цен инструментов (XAUUSD, EURUSD, ...)
# и пересчёта нереализованного PnL открытых позиций «на лету».
# Получить бесплатно: https://twelvedata.com → регистрация → Dashboard → API Keys.
# Free tier: 8 req/min, 800 req/day. На Vercel: Project Settings → Environment Variables.
TWELVEDATA_API_KEY=

# Интервал поллинга цен на клиенте (миллисекунды). По умолчанию 120000 (2 минуты).
# При 2 мин батчем по 6-8 парам = 720 req/день — вписывается в free tier.
# Можно поставить 60000 (1 мин) если торговля идёт только в рабочие часы.
NEXT_PUBLIC_PRICES_REFRESH_MS=120000
